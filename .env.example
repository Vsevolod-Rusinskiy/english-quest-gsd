# URL of the Cloudflare Worker key-proxy. Dev: local `wrangler dev` (default
# 127.0.0.1:8787). Prod: your deployed *.workers.dev URL. The browser now
# talks to this Worker, NOT api.llmrouter.ru directly (quick-260705-rl5).
VITE_LLM_BASE_URL=http://127.0.0.1:8787

# VITE_LLM_API_KEY is NO LONGER required in the browser. The real router key
# lives only in the Worker's secret (worker/.dev.vars for local `wrangler dev`,
# `wrangler secret put LLM_API_KEY` for production). Leave this unset, or set
# it to any placeholder value — it is never forwarded upstream.
# VITE_LLM_API_KEY=proxied-via-worker
